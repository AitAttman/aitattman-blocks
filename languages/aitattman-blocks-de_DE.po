#: build/button/block.json
msgctxt "block title"
msgid "Button"
msgstr "Button"

#: build/button/block.json
msgctxt "block description"
msgid "Display button or link with integrated SVG icon support."
msgstr "Zeige einen Button oder Link mit integrierter SVG-Icon-Unterstützung an."

#: build/query/block.json
msgctxt "block title"
msgid "Query Posts"
msgstr "Beiträge abfragen"

#: build/query/block.json
msgctxt "block description"
msgid "Custom query to display posts filtered by category and post type."
msgstr "Benutzerdefinierte Abfrage zum Anzeigen von Beiträgen, gefiltert nach Kategorie und Inhaltstyp."

#: build/searchbox/block.json
msgctxt "block title"
msgid "Search Box"
msgstr "Suchfeld"

#: build/searchbox/block.json
msgctxt "block description"
msgid "Search posts filtered specifically by the active post type."
msgstr "Suche nach Beiträgen, speziell gefiltert nach dem aktiven Inhaltstyp."

#: build/sidepanel/block.json
msgctxt "block title"
msgid "Side Panel"
msgstr "Seiten-Panel"

#: build/sidepanel/block.json
msgctxt "block description"
msgid "Slide-out drawer for any side of the screen, triggered by a button you choose."
msgstr "Ausziehbares Panel für jede Bildschirmseite, ausgelöst durch einen Button Ihrer Wahl."

#: build/slider/block.json
msgctxt "block title"
msgid "Slider"
msgstr "Slider"

#: build/slider/block.json
msgctxt "block description"
msgid "Display your latest posts in a responsive, single-slide carousel."
msgstr "Zeige deine neuesten Beiträge in einem responsiven Karussell an."

#: build/theme-controllers/block.json
msgctxt "block title"
msgid "Theme Controllers"
msgstr "Theme-Steuerung"

#: build/theme-controllers/block.json
msgctxt "block description"
msgid "Let user choose between light and dark modes anytime."
msgstr "Ermöglicht dem Benutzer jederzeit den Wechsel zwischen Hell- und Dunkelmodus."
