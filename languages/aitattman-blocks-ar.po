#: build/button/block.json
msgctxt "block title"
msgid "Button"
msgstr "زر"

#: build/button/block.json
msgctxt "block description"
msgid "Display button or link with integrated SVG icon support."
msgstr "عرض زر أو رابط مع دعم متكامل لأيقونات SVG."

#: build/query/block.json
msgctxt "block title"
msgid "Query Posts"
msgstr "استعلام المقالات"

#: build/query/block.json
msgctxt "block description"
msgid "Custom query to display posts filtered by category and post type."
msgstr "استعلام مخصص لعرض المقالات المصفاة حسب الفئة ونوع المقال."

#: build/searchbox/block.json
msgctxt "block title"
msgid "Search Box"
msgstr "صندوق البحث"

#: build/searchbox/block.json
msgctxt "block description"
msgid "Search posts filtered specifically by the active post type."
msgstr "البحث في المقالات المصفاة خصيصاً حسب نوع المقال النشط."

#: build/sidepanel/block.json
msgctxt "block title"
msgid "Side Panel"
msgstr "لوحة جانبية"

#: build/sidepanel/block.json
msgctxt "block description"
msgid "Slide-out drawer for any side of the screen, triggered by a button you choose."
msgstr "درج منزلق لأي جانب من الشاشة، يتم تشغيله بواسطة زر تختاره."

#: build/slider/block.json
msgctxt "block title"
msgid "Slider"
msgstr "سلايدر (Slider)"

#: build/slider/block.json
msgctxt "block description"
msgid "Display your latest posts in a responsive, single-slide carousel."
msgstr "اعرض أحدث مقالاتك في شريط متحرك متجاوب."

#: build/theme-controllers/block.json
msgctxt "block title"
msgid "Theme Controllers"
msgstr "متحكمات القالب"

#: build/theme-controllers/block.json
msgctxt "block description"
msgid "Let user choose between light and dark modes anytime."
msgstr "السماح للمستخدم بالاختيار بين الوضع المضيء والمظلم في أي وقت."
