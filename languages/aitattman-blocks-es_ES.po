#: build/button/block.json
msgctxt "block title"
msgid "Button"
msgstr "Botón"

#: build/button/block.json
msgctxt "block description"
msgid "Display button or link with integrated SVG icon support."
msgstr "Muestra un botón o enlace con soporte integrado para iconos SVG."

#: build/query/block.json
msgctxt "block title"
msgid "Query Posts"
msgstr "Consulta de entradas"

#: build/query/block.json
msgctxt "block description"
msgid "Custom query to display posts filtered by category and post type."
msgstr "Consulta personalizada para mostrar entradas filtradas por categoría y tipo de contenido."

#: build/searchbox/block.json
msgctxt "block title"
msgid "Search Box"
msgstr "Caja de búsqueda"

#: build/searchbox/block.json
msgctxt "block description"
msgid "Search posts filtered specifically by the active post type."
msgstr "Busca entradas filtradas específicamente por el tipo de contenido activo."

#: build/sidepanel/block.json
msgctxt "block title"
msgid "Side Panel"
msgstr "Panel lateral"

#: build/sidepanel/block.json
msgctxt "block description"
msgid "Slide-out drawer for any side of the screen, triggered by a button you choose."
msgstr "Panel deslizante para cualquier lado de la pantalla, activado por el botón que elijas."

#: build/slider/block.json
msgctxt "block title"
msgid "Slider"
msgstr "Slider"

#: build/slider/block.json
msgctxt "block description"
msgid "Display your latest posts in a responsive, single-slide carousel."
msgstr "Muestra tus últimas entradas en un carrusel adaptable de una sola diapositiva."

#: build/theme-controllers/block.json
msgctxt "block title"
msgid "Theme Controllers"
msgstr "Controladores de tema"

#: build/theme-controllers/block.json
msgctxt "block description"
msgid "Let user choose between light and dark modes anytime."
msgstr "Permite al usuario elegir entre el modo claro y oscuro en cualquier momento."
