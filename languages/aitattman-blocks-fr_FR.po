#: build/button/block.json
msgctxt "block title"
msgid "Button"
msgstr "Bouton"

#: build/button/block.json
msgctxt "block description"
msgid "Display button or link with integrated SVG icon support."
msgstr "Affiche un bouton ou un lien avec prise en charge intégrée des icônes SVG."

#: build/query/block.json
msgctxt "block title"
msgid "Query Posts"
msgstr "Requête d'articles"

#: build/query/block.json
msgctxt "block description"
msgid "Custom query to display posts filtered by category and post type."
msgstr "Requête personnalisée pour afficher des articles filtrés par catégorie et type d'article."

#: build/searchbox/block.json
msgctxt "block title"
msgid "Search Box"
msgstr "Boîte de recherche"

#: build/searchbox/block.json
msgctxt "block description"
msgid "Search posts filtered specifically by the active post type."
msgstr "Rechercher des articles filtrés spécifiquement par le type d'article actif."

#: build/sidepanel/block.json
msgctxt "block title"
msgid "Side Panel"
msgstr "Panneau latéral"

#: build/sidepanel/block.json
msgctxt "block description"
msgid "Slide-out drawer for any side of the screen, triggered by a button you choose."
msgstr "Tiroir coulissant pour n'importe quel côté de l'écran, déclenché par un bouton de votre choix."

#: build/slider/block.json
msgctxt "block title"
msgid "Slider"
msgstr "Curseur"

#: build/slider/block.json
msgctxt "block description"
msgid "Display your latest posts in a responsive, single-slide carousel."
msgstr "Affichez vos derniers articles dans un carrousel réactif à diapositive unique."

#: build/theme-controllers/block.json
msgctxt "block title"
msgid "Theme Controllers"
msgstr "Contrôleurs de thème"

#: build/theme-controllers/block.json
msgctxt "block description"
msgid "Let user choose between light and dark modes anytime."
msgstr "Permet à l'utilisateur de choisir entre les modes clair et sombre à tout moment."
